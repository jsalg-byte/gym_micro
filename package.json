{
  "name": "gym-micro",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:create": "node scripts/run-with-env.mjs node scripts/db-create.mjs",
    "db:migrate": "node scripts/run-with-env.mjs node ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:setup": "npm run db:create && npm run db:migrate",
    "db:studio": "node scripts/run-with-env.mjs node ./node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "@zxing/browser": "^0.1.5",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.10.0",
    "next": "^15.5.12",
    "next-auth": "^4.24.13",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "^15.5.12",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
